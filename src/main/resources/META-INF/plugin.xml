<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>com.github.mmrsic.idea.plugins.ti-basic</id>
    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>TI-Basic</name>
    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.github.com/mmrsic">mmrsic</vendor>
    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        <p>IntelliJ IDEA plugin for <b>TI-Basic</b> and <b>TI Extended Basic</b> — the BASIC dialects
        of the Texas Instruments TI-99/4 and TI-99/4A home computers.</p>
        <ul>
            <li>Recognizes <code>.tibasic</code>, <code>.ti-basic</code>, and <code>.ti.bas</code> source
                files with a custom file icon</li>
            <li><b>Syntax highlighting</b> for keywords, operators, string literals, and line numbers</li>
            <li><b>Error and warning annotations</b>: invalid/out-of-range line numbers, type mismatches,
                undefined labels, bad file I/O specifications, duplicate line numbers, non-ascending order,
                variable name conflicts, and more</li>
            <li><b>Code completion</b> (Ctrl+Space) for variables and array subscripts</li>
            <li><b>Shift+Enter</b> smart handler that auto-inserts the next available line number</li>
            <li><b>Format TI-Basic Code</b> action: uppercases keywords, normalizes whitespace,
                preserves string literals</li>
            <li><b>Resequence Line Numbers</b> action: renumbers all lines with configurable start and step</li>
            <li><b>Selection screen preview</b> action: renders a 32x24 TI-Basic screen preview for selected
                CALL HCHAR/VCHAR statements, taking selected CALL CHAR/COLOR/SCREEN/CLEAR context into account</li>
            <li>Full statement set: LET, DEF, PRINT (incl. file output), INPUT (incl. file), DISPLAY,
                READ, DATA, RESTORE (incl. file), CALL, GOTO, GOSUB/RETURN, ON GOTO/GOSUB,
                IF/THEN/ELSE, FOR/NEXT, DIM, OPTION BASE, RANDOMIZE, OPEN, CLOSE, REM, END, STOP, and more</li>
            <li>All 10 CALL subprograms: CLEAR, SCREEN, COLOR, HCHAR, VCHAR, GCHAR, CHAR, KEY, JOYST, SOUND</li>
            <li>All built-in numeric and string functions: ABS, SIN, COS, TAN, ATN, EXP, LOG, SQR, INT, RND,
                SGN, ASC, LEN, POS, VAL, STR$, CHR$, SEG$</li>
        </ul>
    ]]></description>
    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <resource-bundle>messages.TiBasicBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="TI-Basic File"
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.lang.TiBasicFileType"
                fieldName="INSTANCE"
                extensions="ti-basic;tibasic;ti.bas"
        />
        <fileIconProvider implementation="com.github.mmrsic.idea.plugins.tibasic.lang.TiBasicFileIconProvider"/>
        <lang.syntaxHighlighterFactory
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.highlight.TiBasicSyntaxHighlighterFactory"
                language="TI-Basic"
        />
        <lang.documentationProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCharacterCodeDocumentationProvider"
        />
        <completion.contributor
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCompletionContributor"
        />
        <typedHandler
                implementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicPairedCharacterTypedHandler"/>
        <backspaceHandlerDelegate
                implementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicPairedCharacterBackspaceHandler"/>
        <lang.parserDefinition
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.parser.TiBasicParserDefinition"
        />
        <annotator
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.highlight.TiBasicAnnotator"
        />
        <codeInsight.lineMarkerProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCallCharLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCallColorLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCallScreenLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicCallSoundLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicLineReferenceLineMarkerProvider"
        />
        <applicationService
                serviceImplementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicColumnHintSettings"
        />
        <editorActionHandler
                action="EditorDuplicate"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicDuplicateLineHandler"
        />
        <copyPastePreProcessor
                implementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicPastePreProcessor"
        />
        <editorActionHandler
                action="EditorStartNewLine"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicShiftEnterHandler"
        />
        <editorActionHandler
                action="EditorEnter"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicEnterHandler"
        />
        <lang.braceMatcher
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicBraceMatcher"
        />
        <applicationService
                serviceImplementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicParenAutoCloseSettings"
        />
        <applicationService
                serviceImplementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicAutoLineNumberSettings"
        />
        <applicationService
                serviceImplementation="com.github.mmrsic.idea.plugins.tibasic.toolwindow.TiBasicVariableToolWindowSettings"
        />
        <postStartupActivity
                implementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicDisplayColumnGuideInitializer"
        />
        <postStartupActivity
                implementation="com.github.mmrsic.idea.plugins.tibasic.action.format.TiBasicReformatCodeActionOverrideInitializer"
        />
        <applicationConfigurable
                parentId="editor"
                instance="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicDisplayColumnGuideConfigurable"
                id="tibasic.display.column.guides"
                key="display.columns.settings.title"
                bundle="messages.TiBasicBundle"
        />
        <applicationConfigurable
                parentId="editor"
                instance="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicParenAutoCloseConfigurable"
                id="tibasic.paren.auto.close"
                key="paren.auto.close.settings.title"
                bundle="messages.TiBasicBundle"
        />
        <applicationConfigurable
                parentId="editor"
                instance="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicAutoLineNumberConfigurable"
                id="tibasic.auto.line.number"
                key="auto.line.number.settings.title"
                bundle="messages.TiBasicBundle"
        />
        <lang.findUsagesProvider
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.findusages.TiBasicFindUsagesProvider"
        />
        <findUsagesHandlerFactory
                implementation="com.github.mmrsic.idea.plugins.tibasic.findusages.TiBasicFindUsagesHandlerFactory"
        />
        <gotoDeclarationHandler
                implementation="com.github.mmrsic.idea.plugins.tibasic.editor.TiBasicGotoDeclarationHandler"/>
        <targetElementEvaluator
                language="TI-Basic"
                implementationClass="com.github.mmrsic.idea.plugins.tibasic.findusages.TiBasicTargetElementEvaluator"
        />
        <readWriteAccessDetector
                implementation="com.github.mmrsic.idea.plugins.tibasic.findusages.TiBasicReadWriteAccessDetector"
        />
        <!--suppress PluginXmlValidity -->
        <toolWindow
                id="TI Basic Variables"
                anchor="bottom"
                icon="icons/ti99_4a_icon_small.svg"
                factoryClass="com.github.mmrsic.idea.plugins.tibasic.toolwindow.TiBasicVariableToolWindowFactory"
        />
        <!--suppress PluginXmlValidity -->
        <toolWindow
                id="TI Basic Character Definitions"
                anchor="bottom"
                icon="icons/ti99_4a_icon_small.svg"
                factoryClass="com.github.mmrsic.idea.plugins.tibasic.toolwindow.TiBasicCharacterDefinitionsToolWindowFactory"
        />
    </extensions>
    <actions>
        <action
                id="TiBasic.ResequenceLineNumbers"
                class="com.github.mmrsic.idea.plugins.tibasic.action.resequence.ResequenceAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
        <action
                id="TiBasic.FormatCode"
                class="com.github.mmrsic.idea.plugins.tibasic.action.format.FormatAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
        <action
                id="TiBasic.ShowScreenPreview"
                class="com.github.mmrsic.idea.plugins.tibasic.action.preview.TiBasicScreenPreviewAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
