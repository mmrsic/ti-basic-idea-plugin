# Gradle build output
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IntelliJ IDEA project files
.idea/
*.iws
*.iml
*.ipr
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/libraries/
out/
!**/src/main/**/out/
!**/src/test/**/out/

# Eclipse project files
.apt_generated/
.classpath
.factorypath
.project
.settings/
springBeans/
sts4-cache/
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans project files
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code project files
.vscode/

# macOS system files
.DS_Store

# Kotlin build output
.kotlin/

# IntelliJ Platform plugin sandbox
/.intellijPlatform/

# Ignore books and generated resources
/resources/books/

# Ignore test results and reports
/test-results/
/build/reports/

# Ignore temporary files
/tmp/

# Ignore jar extracts
/build/libs/*.jar
/build/libs/*.zip
/build/libs/*.tar

# Allow versioned files in src/main and src/test
!**/src/main/**/build/
!**/src/test/**/build/

# End of file